# WardenStrike - Environment Variables
# Copy this file to .env and fill in your API keys

# Anthropic (Claude) - Required for AI features
ANTHROPIC_API_KEY=

# Burp Suite REST API
WARDENSTRIKE_BURP_URL=http://127.0.0.1:1337
WARDENSTRIKE_BURP_KEY=

# OWASP ZAP API
WARDENSTRIKE_ZAP_URL=http://127.0.0.1:8081
WARDENSTRIKE_ZAP_KEY=

# Proxy (for routing through Burp/ZAP)
WARDENSTRIKE_PROXY=

# Recon API Keys
SHODAN_API_KEY=
VT_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
SECURITYTRAILS_KEY=
CHAOS_KEY=
GITHUB_TOKEN=
HUNTER_API_KEY=
FULLHUNT_API_KEY=
