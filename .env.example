# WardenStrike - Environment Variables
# cp .env.example .env  →  luego editar con tus claves

# ═══════════════════════════════════════════════════════════════
# OBLIGATORIO - AI Engine
# ═══════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-api03-...

# ═══════════════════════════════════════════════════════════════
# SCANNER INTEGRATIONS
# ═══════════════════════════════════════════════════════════════

# Burp Suite Professional REST API
# Activar en: User options → Misc → REST API Service
WARDENSTRIKE_BURP_URL=http://127.0.0.1:1337
WARDENSTRIKE_BURP_KEY=

# OWASP ZAP
# Iniciar: zaproxy -daemon -port 8081 -config api.key=TU_KEY
WARDENSTRIKE_ZAP_URL=http://127.0.0.1:8081
WARDENSTRIKE_ZAP_KEY=

# Nessus / Tenable.io
NESSUS_URL=https://localhost:8834
NESSUS_ACCESS_KEY=
NESSUS_SECRET_KEY=
# NESSUS_USERNAME=admin
# NESSUS_PASSWORD=

# Metasploit MSFRPC
# Iniciar: msfrpcd -P TU_PASSWORD -S -a 127.0.0.1
MSF_RPC_HOST=127.0.0.1
MSF_RPC_PORT=55553
MSF_RPC_PASSWORD=msfrpc_password

# ═══════════════════════════════════════════════════════════════
# OSINT API KEYS
# ═══════════════════════════════════════════════════════════════

# Shodan - https://account.shodan.io/
SHODAN_API_KEY=

# GitHub - https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Have I Been Pwned - https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# Censys - https://search.censys.io/account
CENSYS_API_ID=
CENSYS_API_SECRET=

# SecurityTrails - https://securitytrails.com/app/account/credentials
SECURITYTRAILS_KEY=

# Chaos (Project Discovery) - https://chaos.projectdiscovery.io/
CHAOS_KEY=

# Hunter.io (email finder)
HUNTER_API_KEY=

# FullHunt - https://fullhunt.io/
FULLHUNT_API_KEY=

# VirusTotal
VT_API_KEY=

# ═══════════════════════════════════════════════════════════════
# CLOUD PROVIDERS
# ═══════════════════════════════════════════════════════════════

AWS_DEFAULT_PROFILE=default
AWS_DEFAULT_REGION=us-east-1
GCP_PROJECT=
AZURE_SUBSCRIPTION=

# ═══════════════════════════════════════════════════════════════
# WEB3
# ═══════════════════════════════════════════════════════════════

ETH_RPC_URL=https://mainnet.infura.io/v3/TU_KEY
ETHERSCAN_API_KEY=

# ═══════════════════════════════════════════════════════════════
# PROXY (rutar tráfico a Burp/ZAP)
# ═══════════════════════════════════════════════════════════════
# WARDENSTRIKE_PROXY=http://127.0.0.1:8080

# ═══════════════════════════════════════════════════════════════
# NOTIFICACIONES (monitoreo continuo)
# ═══════════════════════════════════════════════════════════════
# SLACK_WEBHOOK=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
